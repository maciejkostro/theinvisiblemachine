---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign docs = site.pages | where: "sitemap", true %}
{% for page in docs %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ page.url }}</loc>
    {% if page.last_modified %}<lastmod>{{ page.last_modified }}</lastmod>{% endif %}
  </url>
{% endfor %}
</urlset>
